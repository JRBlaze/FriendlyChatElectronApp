{
  "name": "friendly-chat",
  "version": "1.0.0",
  "description": "Multi-platform stream chat merger for Twitch, YouTube and Kick",
  "author": {
    "name": "JRBlaze",
    "email": "jrblaze@friendly-chat.app"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build":       "electron-builder --win --x64",
    "build:win":   "electron-builder --win --x64",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux --x64",
    "build:all":   "electron-builder --win --mac --linux"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "JRBlaze",
      "repo": "FriendlyChatElectronApp"
    },
    "appId": "com.friendlychat.app",
    "productName": "Friendly Chat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "friendly-chat.html",
      "config.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
